    "import numpy as np\n",
    "from dataclasses import dataclass\n",
    "\n",
    "\n",
    "class GridWorld:\n",
    "    def __init__(self,size):\n",
    "        self.size = size\n",
    "        self.grid = np.zeros((size,size))\n",
    "    def __str__(self):\n",
    "        return \"\\n\".join([\" \".join(map(str, row)) for row in self.grid])\n",
    "\n",
    "\n"
